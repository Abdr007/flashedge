{
  "name": "bolt-terminal",
  "version": "1.2.7",
  "description": "Deterministic on-chain trading infrastructure for Solana perpetual futures",
  "homepage": "https://bolt-terminal-docs.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/Abdr007/bolt-terminal.git"
  },
  "bugs": {
    "url": "https://github.com/Abdr007/bolt-terminal/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "flash": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./sdk": "./dist/sdk/index.js",
    "./sdk/*": "./dist/sdk/*.js"
  },
  "scripts": {
    "build": "sh scripts/generate-build-info.sh && tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "coverage": "vitest run --coverage",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --max-warnings=0"
    ]
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.js.map",
    ".env.example",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "flash-trade",
    "solana",
    "perpetuals",
    "cli",
    "terminal",
    "trading"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@coral-xyz/anchor": "0.32.1",
    "@pythnetwork/client": "2.22.1",
    "@solana/spl-token": "0.4.14",
    "@solana/web3.js": "1.98.4",
    "bs58": "^5.0.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "flash-sdk": "^15.13.1",
    "ora": "^8.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bn.js": "^5.2.0",
    "@types/node": "^22.13.0",
    "@vitest/coverage-v8": "^3.2.4",
    "better-sqlite3": "^12.8.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.0.5"
  }
}
