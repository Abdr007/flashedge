# ─── Solana Connection ─────────────────────────────────────────────────────────

# Primary RPC endpoint (required for live trading)
# Use a premium provider for production: Helius, Triton, QuickNode
# Type: URL | Default: https://api.mainnet-beta.solana.com
RPC_URL=https://api.mainnet-beta.solana.com

# Backup RPC endpoints for automatic failover (optional)
# The RPC manager monitors all endpoints and switches on failure,
# high latency (>5s), or slot lag (>50 slots behind network tip).
# Type: URL | Default: none
# BACKUP_RPC_1=https://your-backup-rpc-1.example.com
# BACKUP_RPC_2=https://your-backup-rpc-2.example.com

# Pyth oracle RPC endpoint
# Type: URL | Default: https://pythnet.rpcpool.com
PYTHNET_URL=https://pythnet.rpcpool.com

# Solana network: mainnet-beta or devnet
# Type: string | Default: mainnet-beta
NETWORK=mainnet-beta

# ─── Wallet ────────────────────────────────────────────────────────────────────

# Path to Solana CLI keypair file (JSON format)
# You can also import wallets interactively via "wallet import <name>"
# Type: filepath | Default: ~/.config/solana/id.json
WALLET_PATH=~/.config/solana/id.json

# Wallet session idle timeout in milliseconds
# Keypair is zeroed from memory after this duration of inactivity
# Type: integer (ms) | Default: 900000 (15 minutes)
# SESSION_TIMEOUT_MS=900000

# ─── Trading ───────────────────────────────────────────────────────────────────

# Simulation mode (paper trading)
# true  = virtual balance, no real transactions (default)
# false = live on-chain execution with real funds
# Type: boolean | Default: true
SIMULATION_MODE=true

# Master trading enable/disable flag (kill switch)
# Set to false to block ALL trade execution (monitoring-only mode)
# Type: boolean | Default: true
# TRADING_ENABLED=true

# Default Flash Trade pool for market resolution
# Type: string | Default: Crypto.1
DEFAULT_POOL=Crypto.1

# Default leverage multiplier when not specified
# Type: integer | Default: 2
# DEFAULT_LEVERAGE=2

# Slippage tolerance in basis points (150 = 1.5%)
# Type: integer | Default: 150
DEFAULT_SLIPPAGE_BPS=150

# ─── Compute Budget ───────────────────────────────────────────────────────────

# Transaction compute unit limit
# Type: integer | Default: 600000
COMPUTE_UNIT_LIMIT=600000

# Priority fee in microLamports
# Type: integer | Default: 500000
COMPUTE_UNIT_PRICE=500000

# Enable dynamic compute unit calculation
# When enabled, the terminal estimates CU usage via simulation and adds a buffer
# Type: boolean | Default: true
# FLASH_DYNAMIC_CU=true

# Buffer percentage added to simulated compute units (only when FLASH_DYNAMIC_CU=true)
# Type: integer (0-100) | Default: 20
# FLASH_CU_BUFFER_PCT=20

# ─── Signing Guards ───────────────────────────────────────────────────────────
# These limits are enforced before every trade confirmation.
# Set to 0 for unlimited (use with caution in live mode).

# Maximum USD collateral allowed per single trade
# Type: number | Default: 0 (unlimited)
MAX_COLLATERAL_PER_TRADE=0

# Maximum USD position size (collateral x leverage)
# Type: number | Default: 0 (unlimited)
MAX_POSITION_SIZE=0

# Maximum leverage multiplier
# Type: number | Default: 0 (use market defaults)
MAX_LEVERAGE=0

# Maximum number of trades allowed per minute
# Type: integer | Default: 10
MAX_TRADES_PER_MINUTE=10

# Minimum milliseconds between consecutive trades
# Type: integer | Default: 3000
MIN_DELAY_BETWEEN_TRADES_MS=3000

# ─── Risk Controls ────────────────────────────────────────────────────────────
# Circuit breaker thresholds. When cumulative losses exceed these limits,
# all trading is halted until the session is reset.

# Maximum total loss allowed per trading session (USD)
# Type: number | Default: 0 (unlimited)
# MAX_SESSION_LOSS_USD=500

# Maximum total loss allowed per calendar day (USD)
# Type: number | Default: 0 (unlimited)
# MAX_DAILY_LOSS_USD=1000

# Maximum total portfolio exposure (USD)
# Type: number | Default: 0 (unlimited)
# MAX_PORTFOLIO_EXPOSURE=10000

# ─── Logging ──────────────────────────────────────────────────────────────────

# Log file path (leave empty for console-only logging)
# Log files auto-rotate at 10MB. API keys are scrubbed from all log output.
# Type: filepath | Default: none (console only)
# LOG_FILE=~/.flash/flash.log

# Log level: debug, info, warn, error
# Type: string | Default: info
# FLASH_LOG_LEVEL=info

# Log output format: text (default) or json (structured)
# JSON format includes timestamp, level, module, message, and request_id fields
# Type: string | Default: text
# FLASH_LOG_FORMAT=text

# ─── Alerts & Webhooks ────────────────────────────────────────────────────────
# Alert consumers are fire-and-forget — they never block the trading pipeline.

# Generic webhook URL for alert delivery (JSON POST)
# Events: trade execution, risk limit triggered, RPC failure, circuit breaker
# Type: URL | Default: none (disabled)
# ALERT_WEBHOOK_URL=https://your-webhook.example.com/alerts

# Slack incoming webhook URL for alert notifications
# Type: URL | Default: none (disabled)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# Minimum alert severity to forward to webhooks: info, warning, critical
# Type: string | Default: warning
# ALERT_MIN_SEVERITY=warning

# ─── Shadow Trading ──────────────────────────────────────────────────────────

# Enable shadow trading mode (risk mirror)
# Mirrors trades to a parallel risk engine for comparison without execution
# Type: boolean | Default: false
# SHADOW_TRADING=false

# ─── Protocol Validation ─────────────────────────────────────────────────────

# Strict protocol validation mode
# When enabled, liquidation price divergence between local and SDK calculations
# throws an error instead of logging a warning
# Type: boolean | Default: false
# FLASH_STRICT_PROTOCOL=false

# ─── Trade Journal ────────────────────────────────────────────────────────────

# Journal persistence backend
# file   = JSON file (default, ~/.flash/pending-trades.json)
# sqlite = SQLite database (~/.flash/journal.db)
# Type: string | Default: file
# JOURNAL_DB=file

# ─── Automation Mode (NO_DNA) ─────────────────────────────────────────────────

# Machine-readable output mode (no-dna.org standard)
# When set, disables TUI elements, uses JSON output, auto-confirms trades
# Designed for scripts and programmatic integration
# Type: any non-empty string to enable | Default: none (disabled)
# NO_DNA=1
